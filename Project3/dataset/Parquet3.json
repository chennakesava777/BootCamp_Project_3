{
	"name": "Parquet3",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ckrsynwp-WorkspaceDefaultStorage",
			"type": "LinkedServiceReference"
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat('cards_', formatDateTime(convertTimeZone(utcNow(),'UTC','Eastern Standard Time'),'yyyy-MM-dd-HH-mm-ss'),'.parquet')",
					"type": "Expression"
				},
				"folderPath": {
					"value": "cards/@{formatDateTime(utcNow(), 'yyyy-MM-dd')}",
					"type": "Expression"
				},
				"fileSystem": "bronze"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	},
	"type": "Microsoft.Synapse/workspaces/datasets"
}