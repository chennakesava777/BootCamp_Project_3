		"cells": [
			{
				"cell_type": "code",
				"source": [
					"silver_path = \"abfss://silver@ckrsynstorage.dfs.core.windows.net/\"\n",
					"gold_path = \"abfss://gold@ckrsynstorage.dfs.core.windows.net/\""
				],
				"execution_count": 50
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"from pyspark.sql.functions import *\n",
					"\n",
					"users_path = silver_path +\"users_cleaned\"\n",
					"\n",
					"silver_users_df = spark.read.format(\"delta\").load(users_path)\n",
					"\n",
					"dim_users = (\n",
					"    silver_users_df\n",
					"    .withColumn(\"client_id\",col(\"user_id\"))\n",
					"    .withColumn(\"current_age\", col(\"current_age\").cast(\"int\"))\n",
					"    .withColumn(\"retirement_age\", col(\"retirement_age\").cast(\"int\"))\n",
					"    .withColumn(\"birth_year\", col(\"birth_year\").cast(\"int\"))\n",
					"    .withColumn(\"birth_month\", col(\"birth_month\").cast(\"int\"))\n",
					"    .withColumn(\"latitude\", col(\"latitude\").cast(\"double\"))\n",
					"    .withColumn(\"longitude\", col(\"longitude\").cast(\"double\"))\n",
					"    .withColumn(\"per_capita_income\", regexp_replace(col(\"per_capita_income\"), \"[$,]\", \"\").cast(\"double\"))\n",
					"    .withColumn(\"yearly_income\", regexp_replace(col(\"yearly_income\"), \"[$,]\", \"\").cast(\"double\"))\n",
					"    .withColumn(\"total_debt\", regexp_replace(col(\"total_debt\"), \"[$,]\", \"\").cast(\"double\"))\n",
					"    .withColumn(\"credit_score\", col(\"credit_score\").cast(\"int\"))\n",
					"    .withColumn(\"num_credit_cards\", col(\"num_credit_cards\").cast(\"int\"))\n",
					"    .drop(col(\"user_id\"))\n",
					")\n",
					"\n",
					"display(dim_users.limit(10))"
				],
				"execution_count": 53
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"cards_path = silver_path +\"cards_cleaned\"\n",
					"\n",
					"silver_cards_df = spark.read.format(\"delta\").load(cards_path)\n",
					"\n",
					"dim_cards = (\n",
					"    silver_cards_df\n",
					"    .withColumn(\"credit_limit\", regexp_replace(col(\"credit_limit\"), \"[$,]\", \"\").cast(\"double\"))\n",
					"    .withColumn(\"expiry_month\", substring(\"expires\", 1, 2).cast(\"int\"))\n",
					"    .withColumn(\"expiry_year\", substring(\"expires\", 4, 4).cast(\"int\"))\n",
					"    .withColumn(\"num_cards_issued\", col(\"num_cards_issued\").cast(\"int\"))\n",
					"    .withColumn(\"acct_open_date\", to_date(\"acct_open_date\"))\n",
					"    .withColumn(\"year_pin_last_changed\", col(\"year_pin_last_changed\").cast(\"int\"))\n",
					"    .dropDuplicates([\"card_id\"])\n",
					"    .drop(col(\"expires\"))\n",
					")\n",
					"\n",
					"display(dim_cards.limit(10))"
				],
				"execution_count": 56
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"transactions_path = silver_path +\"transactions_cleaned\"\n",
					"\n",
					"silver_transactions_df = spark.read.format(\"delta\").load(transactions_path)\n",
					"\n",
					"\n",
					"fact_transactions = (\n",
					"    silver_transactions_df\n",
					"    .withColumn(\"amount\", regexp_replace(col(\"amount\"), \"[$,]\", \"\").cast(\"double\"))\n",
					"    .withColumn(\"mcc\", col(\"mcc\").cast(\"int\"))\n",
					"    .select(\n",
					"        \"transaction_id\",\n",
					"        \"txn_date\",\n",
					"        \"client_id\",\n",
					"        \"card_id\",\n",
					"        \"merchant_id\",\n",
					"        \"amount\",\n",
					"        \"use_chip\",\n",
					"        \"errors\",\n",
					"        \"txn_year\",\n",
					"        \"txn_month_name\",\n",
					"        \"silver_load_time\"\n",
					"    )\n",
					")\n",
					"\n",
					"display(fact_transactions.limit(10))"
				],
				"execution_count": 62
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"dim_merchant = (\n",
					"    silver_transactions_df\n",
					"    .select(\"merchant_id\", \"merchant_city\", \"merchant_state\", \"zip\", \"mcc\")\n",
					"    .dropDuplicates([\"merchant_id\"])\n",
					")\n",
					"\n",
					"display(dim_merchant.limit(10))"
				],
				"execution_count": 43
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"dim_date = (\n",
					"    silver_transactions_df\n",
					"    .select(\"txn_date\", \"txn_year\", \"txn_month_name\")\n",
					"    .dropDuplicates([\"txn_date\"])\n",
					")\n",
					"\n",
					"display(dim_date.limit(10))"
				],
				"execution_count": 45
			},
			{
				"cell_type": "code",
				"source": [
					"def write_gold(df, table_name):\n",
					"    (\n",
					"        df.write\n",
					"        .format(\"delta\")\n",
					"        .mode(\"overwrite\")\n",
					"        .save(f\"{gold_path}{table_name}\")\n",
					"    )"
				],
				"execution_count": 51
			},
			{
				"cell_type": "code",
				"source": [
					"write_gold(dim_cards, \"dim_cards\")\n",
					"write_gold(dim_users, \"dim_users\")\n",
					"write_gold(fact_transactions, \"fact_transactions\")\n",
					"write_gold(dim_merchant_enriched, \"dim_merchant_enriched\")\n",
					"write_gold(dim_date, \"dim_date\")"
				],
				"execution_count": 52
			},
			{
				"cell_type": "code",
				"source": [
					"write_gold(fact_transactions, \"fact_transactions\")"
				],
				"execution_count": 63
			},
