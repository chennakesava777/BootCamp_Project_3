		"cells": [
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 1 — IMPORT REQUIRED LIBRARIES\n",
					"# =====================================================\n",
					"\n",
					"from notebookutils import mssparkutils\n",
					"\n",
					"from pyspark.sql.functions import *\n",
					"from pyspark.sql.types import *"
				],
				"execution_count": 27
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 2 — DEFINE BRONZE & SILVER PATHS\n",
					"# =====================================================\n",
					"\n",
					"bronze_base_path = \"abfss://bronze@ckrsynstorage.dfs.core.windows.net/users/\"\n",
					"silver_path = \"abfss://silver@ckrsynstorage.dfs.core.windows.net/users_cleaned/\""
				],
				"execution_count": 29
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 3 — GET ALL DATE FOLDERS\n",
					"# =====================================================\n",
					"\n",
					"folders = mssparkutils.fs.ls(bronze_base_path)\n",
					"\n",
					"date_folders = [\n",
					"    folder.name.replace(\"/\", \"\")\n",
					"    for folder in folders\n",
					"    if folder.isDir\n",
					"]\n",
					"\n",
					"print(date_folders)"
				],
				"execution_count": 15
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 4 — FIND LATEST DATE FOLDER\n",
					"# =====================================================\n",
					"\n",
					"import builtins\n",
					"\n",
					"latest_folder = builtins.max(date_folders)\n",
					"print(\"Latest Folder:\", latest_folder)"
				],
				"execution_count": 16
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 5 — BUILD FULL PATH OF LATEST FOLDER\n",
					"# =====================================================\n",
					"\n",
					"latest_folder_path = bronze_base_path + latest_folder + \"/\"\n",
					"\n",
					"print(latest_folder_path)"
				],
				"execution_count": 17
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 6 — GET FILES INSIDE LATEST FOLDER\n",
					"# =====================================================\n",
					"\n",
					"files = mssparkutils.fs.ls(latest_folder_path)\n",
					"\n",
					"data_files = [\n",
					"    file.path\n",
					"    for file in files\n",
					"    if file.name.endswith(\".parquet\")\n",
					"]\n",
					"\n",
					"print(data_files)"
				],
				"execution_count": 18
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 7 — CHECK IF FILE EXISTS\n",
					"# =====================================================\n",
					"\n",
					"if len(data_files) == 0:\n",
					"    \n",
					"    print(\"No parquet files found\")\n",
					"    \n",
					"    mssparkutils.notebook.exit(\n",
					"        \"Notebook stopped - no files to process\"\n",
					"    )"
				],
				"execution_count": 19
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 8 — READ PARQUET FILES\n",
					"# =====================================================\n",
					"\n",
					"df = spark.read.parquet(*data_files)\n",
					"\n",
					"df.show(5)"
				],
				"execution_count": 20
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"# =====================================================\n",
					"# STEP 9 — APPLY TRANSFORMATIONS\n",
					"# =====================================================\n",
					"\n",
					"df_transformed = (\n",
					"    df\n",
					"    .withColumn(\"user_id\",col(\"id\")).drop(col(\"id\"))\n",
					"    .withColumn(\"load_date\", current_date())\n",
					"    .withColumn(\"load_timestamp\", current_timestamp())\n",
					"    .withColumn(\"source_folder\", lit(latest_folder))\n",
					")\n",
					"\n",
					"display(df_transformed.limit(10))"
				],
				"execution_count": 22
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 10 — OPTIONAL DATA CLEANING\n",
					"# =====================================================\n",
					"\n",
					"df_cleaned = (\n",
					"    df_transformed\n",
					"    .dropDuplicates([\"user_id\"])\n",
					"    .filter(col(\"user_id\").isNotNull())\n",
					")"
				],
				"execution_count": 23
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 11 — WRITE TO SILVER DELTA TABLE\n",
					"# =====================================================\n",
					"\n",
					"(\n",
					"    df_cleaned\n",
					"    .write\n",
					"    .format(\"delta\")\n",
					"    .mode(\"append\")\n",
					"    .save(silver_path)\n",
					")"
				],
				"execution_count": 24
			},
			{
				"cell_type": "code",
				"metadata": {
					"run_control": {
						"frozen": true
					},
					"editable": false
				},
				"source": [
					"# =====================================================\n",
					"# STEP 12 — CREATE DELTA TABLE (OPTIONAL)\n",
					"# =====================================================\n",
					"\n",
					"spark.sql(f\"\"\"\n",
					"CREATE TABLE IF NOT EXISTS silver_users\n",
					"USING DELTA\n",
					"LOCATION '{silver_path}'\n",
					"\"\"\")"
				],
				"execution_count": 26
			},
			{
				"cell_type": "code",
				"source": [
					"# =====================================================\n",
					"# STEP 13 — VALIDATE DATA\n",
					"# =====================================================\n",
					"\n",
					"silver_df = spark.read.format(\"delta\").load(silver_path)\n",
					"\n",
					"silver_df.show(10)"
				],
				"execution_count": 25
			},
			{
				"cell_type": "code",
				"source": [
					"silver_df = spark.read.format(\"delta\").load(silver_path)\n",
					"\n",
					"silver_df.show(10)"
				],
				"execution_count": 30
			},
			{
				"cell_type": "code",
				"source": [
					"silver_df.printSchema()"
				],
				"execution_count": 31
			}
		]
	}
